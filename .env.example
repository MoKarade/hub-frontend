# Hub Frontend env

# URL du backend hub-core
# En dev local : http://localhost:8000
# En prod via Caddy : /api (chemin relatif)
NEXT_PUBLIC_HUB_API_URL=http://localhost:8000

# Google Maps API key (optionnelle — sans clé, fallback OpenStreetMap/Leaflet)
# Pour l'obtenir gratuitement (28k loads/mois) :
#   1. https://console.cloud.google.com/google/maps-apis
#   2. Créer un projet → activer "Maps JavaScript API"
#   3. Créer une clé API → restreindre à localhost:3000 + ton domaine
#   4. Coller la clé ici
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
